rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdminEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function isValidImage() {
      return request.resource.size < 2 * 1024 * 1024  // Max 2MB
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|avif)');
    }

    // Product images: Anyone can read, only verified+authenticated can upload
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminEmail() && isValidImage();
    }

    // Category images: Anyone can read, only verified+authenticated can upload
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminEmail() && isValidImage();
    }
  }
}
